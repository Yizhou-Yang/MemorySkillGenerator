# SkillForge environment variable configuration
# Copy this file to .env and fill in actual values

# ===== LLM API Configuration =====
# DeepSeek API (recommended — strong reasoning capability)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# HunYuan API (alternative — low latency on internal platform)
HUNYUAN_API_KEY=your_hunyuan_api_key_here
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_MODEL=hunyuan-turbo

# Default LLM provider (deepseek / hunyuan)
LLM_PROVIDER=deepseek

# ===== Embedding Configuration =====
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DEVICE=cpu

# ===== Mem0 Configuration =====
MEM0_VECTOR_STORE=chromadb
MEM0_COLLECTION_NAME=skillforge_memory

# ===== Experiment Configuration =====
EXPERIMENT_DIR=./experiments
LOG_LEVEL=INFO
