# MemorySkillGenerator environment variable configuration
# Copy this file to .env and fill in actual values

# ===== LLM API Configuration =====
# The pipeline runs against any OpenAI-compatible chat endpoint. You do NOT need
# the Tencent-internal CodeBuddy CLI: when it is absent, every LLM call (including
# GAIA2 native tool-calling) routes to the endpoint configured here automatically.
#
# Reviewers: set the three OPENAI_* vars below to any OpenAI-compatible endpoint
# (OpenAI, DeepSeek, a vLLM/TGI server, a gateway). Function-calling support is
# required for the GAIA2 agent; the other benchmarks only need plain chat.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o
# Force the OpenAI path even where CodeBuddy is installed:
# LLM_PROVIDER=openai

# DeepSeek Official API (OpenAI-compatible; also accepted as a fallback for the
# OPENAI_* vars above, so filling these in alone is enough).
#   - Create API Key at: https://platform.deepseek.com/api_keys
#   - Available models: deepseek-chat (V3), deepseek-reasoner (R1)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== Embedding Configuration =====
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DEVICE=cpu

# ===== Mem0 Configuration =====
MEM0_VECTOR_STORE=chromadb
MEM0_COLLECTION_NAME=memskillgen_memory

# ===== Experiment Configuration =====
EXPERIMENT_DIR=./experiments
LOG_LEVEL=INFO
